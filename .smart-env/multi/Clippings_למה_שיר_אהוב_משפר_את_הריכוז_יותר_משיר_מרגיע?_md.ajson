a7bf-bff75ec70000/e4/30/c6cdb9274635b67f5c22574740d0/445075.jpg?&width=1500&height=1002&cmsprod","line":32,"embedded":true},{"title":"האזנה למוזיקה. כאשר המשימה עצמה משעממת או מתישה, היא מוסיפה רכיב של הנאה שמפחית את תחושת ההתנגדות","target":"https://img.haarets.co.il/bs/0000019d-a4f7-d31c-a1df-aef73d120000/63/8f/aecfdc1a4844afc1ddc86710fd47/360451.jpg?&width=1500&height=1002&cmsprod","line":48,"embedded":true}],"metadata":{"title":"למה שיר אהוב משפר את הריכוז יותר משיר מרגיע?","source":"https://www.haaretz.co.il/health/mikud/2026-04-20/ty-article-magazine/.premium/0000019d-a4b1-d6af-a7bf-bff1b7200000","author":["[[שירלי הרשקו]]"],"published":"2026-04-20","created":"2026-04-21","description":"האזנה למוזיקה אהובה שיפרה ביצועים במשימות קשב מתמשך לצד עלייה בערנות, אך במשימות מורכבות נרשמה ירידה. מתי היא מסייעת ומתי היא פוגעת, ואיך לעבוד איתה בלי לאבד ריכוז?","tags":["#clippings"]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},"smart_blocks:Clippings/למה שיר אהוב משפר את הריכוז יותר משיר מרגיע?.md#---frontmatter---": {"path":null,"last_embed":{"hash":"11w5706","at":1776752151033},"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.07429007,-0.000371,0.00376525,-0.00593615,0.02219484,-0.00430165,-0.00725531,0.07291011,0.04456253,0.00781738,-0.01883514,-0.05496129,0.02700018,0.03696933,0.02784867,-0.00682339,0.037758,0.01582237,-0.06212875,0.02066295,0.09414317,-0.05472394,0.06629545,-0.07859535,0.05121017,0.00898561,-0.03093709,-0.04394756,-0.06602995,-0.16983975,0.03813781,0.02068612,0.09648269,-0.00819551,-0.02008218,0.01089339,-0.02549377,0.07558518,0.01317704,0.06505866,0.08276965,0.04028961,-0.05370583,-0.053395,-0.03067775,-0.0285705,-0.03562623,-0.03093669,-0.00950236,0.02391555,-0.09226906,-0.02028046,0.04010783,-0.03245253,0.0735096,0.00865708,0.0325947,0.02415504,-0.02184945,0.05323144,0.03830097,-0.01796965,-0.21885441,0.08310766,-0.02404845,0.02234413,0.01901528,-0.01513322,-0.01796279,-0.02117876,-0.03290868,0.02201005,0.00075392,0.03389414,-0.01074553,-0.0